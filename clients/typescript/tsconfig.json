{
  "compilerOptions": {
    "declaration": true,
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node10",
    "rootDir": "src",
    "outDir": "dist",
    "ignoreDeprecations": "6.0",
    "typeRoots": ["node_modules/@types"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
