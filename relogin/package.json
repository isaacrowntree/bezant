{
  "name": "bezant-relogin",
  "version": "0.1.0",
  "private": true,
  "description": "Pi-side IBKR Gateway re-login service. Runs Playwright on a systemd timer, fills credentials, waits for IB Key approval.",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "start": "tsx index.ts",
    "install-browsers": "playwright install --with-deps chromium"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "playwright": "^1.50.1",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
